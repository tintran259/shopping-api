# ── App ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api
# Comma-separated list of allowed CORS origins (storefront, CMS admin, etc.)
CORS_ORIGINS=http://localhost:3001,http://localhost:1337

# ── Database (PostgreSQL) ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=shopping
DB_PASSWORD=shopping
DB_NAME=shopping_api
# Dev convenience: auto-create/update tables from entities. NEVER true in prod.
DB_SYNCHRONIZE=true
DB_LOGGING=false

# ── Auth (JWT) ───────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# ── Seed (optional bootstrap admin) ──────────────────────────────────
SEED_ADMIN_EMAIL=admin@shopping.local
SEED_ADMIN_PASSWORD=admin12345

# ── GHN (Giao Hàng Nhanh) shipping carrier ────────────────────────────
# Sandbox gateway by default; switch to https://online-gateway.ghn.vn/shiip/public-api in prod.
GHN_BASE_URL=https://dev-online-gateway.ghn.vn/shiip/public-api
GHN_TOKEN=
# Fallback shop id when a branch has no ghnShopId of its own.
GHN_DEFAULT_SHOP_ID=

# ── GHTK (Giao Hàng Tiết Kiệm) shipping carrier ───────────────────────
GHTK_BASE_URL=https://services.giaohangtietkiem.vn
GHTK_TOKEN=
# "X-Client-Source" header — issued alongside the token.
GHTK_CLIENT_SOURCE=
